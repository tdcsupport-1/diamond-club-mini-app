:root {
  --bg: #030812;
  --card: rgba(9, 25, 43, 0.72);
  --card-strong: rgba(11, 35, 58, 0.9);
  --line: rgba(160, 220, 255, 0.22);
  --text: #eef8ff;
  --muted: #98aec0;
  --blue: #9adfff;
  --green: #45d27a;
  --red: #ff5d6c;
  --silver: #d8e9f7;
}

* { box-sizing: border-box; }

body {
  margin: 0;
  min-height: 100vh;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background:
    radial-gradient(circle at 50% 0%, rgba(142, 216, 255, 0.25), transparent 34rem),
    radial-gradient(circle at 15% 22%, rgba(56, 118, 168, 0.16), transparent 18rem),
    linear-gradient(180deg, #020713 0%, #071322 54%, #02060c 100%);
  color: var(--text);
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  background-image:
    radial-gradient(circle at 50% 8%, rgba(207, 241, 255, 0.12), transparent 16rem),
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: auto, 44px 44px, 44px 44px;
  pointer-events: none;
}

.app-shell {
  position: relative;
  max-width: 980px;
  margin: 0 auto;
  padding: 18px 14px 30px;
}

.glass-card {
  background: linear-gradient(145deg, rgba(12, 31, 54, 0.88), rgba(3, 12, 22, 0.76));
  border: 1px solid var(--line);
  box-shadow: 0 18px 48px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255,255,255,0.08);
  backdrop-filter: blur(14px);
  border-radius: 24px;
}

.hero {
  position: relative;
  display: grid;
  gap: 4px;
  padding: 20px 14px 18px;
  text-align: center;
  overflow: hidden;
  min-height: 285px;
  place-items: center;
}

.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(115deg, transparent 0 34%, rgba(172, 226, 255, 0.08) 46%, transparent 58% 100%),
    radial-gradient(circle at 50% 34%, rgba(125, 207, 255, 0.18), transparent 18rem);
  pointer-events: none;
}

.hero-glow {
  position: absolute;
  width: min(92vw, 720px);
  height: 220px;
  border-radius: 999px;
  background:
    radial-gradient(circle at 50% 35%, rgba(240, 250, 255, 0.18), transparent 34%),
    radial-gradient(circle at 50% 50%, rgba(120, 213, 255, 0.18), transparent 66%);
  filter: blur(24px);
}

.club-logo {
  position: relative;
  z-index: 1;
  display: block;
  width: min(96%, 680px);
  max-height: 250px;
  object-fit: contain;
  margin: 0 auto -2px;
  opacity: 1;
  filter:
    drop-shadow(0 0 10px rgba(226, 246, 255, 0.42))
    drop-shadow(0 0 26px rgba(112, 205, 255, 0.42));
}

.hero-copy {
  position: relative;
  z-index: 1;
}

.hero-copy.compact {
  margin-top: -2px;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin: 0;
  padding: 6px 12px;
  border: 1px solid rgba(154, 223, 255, 0.2);
  border-radius: 999px;
  background: rgba(154, 223, 255, 0.08);
  color: var(--blue);
  text-transform: uppercase;
  letter-spacing: 0.14em;
  font-size: 0.72rem;
}

.eyebrow::before,
.eyebrow::after {
  content: "◆";
  font-size: 0.58rem;
  opacity: 0.75;
}

h1, h2, p { margin-top: 0; }

h1 {
  margin: 4px 0 4px;
  font-size: clamp(2rem, 8vw, 4.2rem);
  letter-spacing: 0.04em;
}

.subtitle { color: var(--muted); margin: 8px 0 0; }

.clock-grid, .market-panel, .time-panel { margin-top: 14px; padding: 16px; }

.section-title {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}

.section-title h2 {
  margin: 0;
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.section-title span { color: var(--blue); }
.no-margin { margin-bottom: 0; }

.session-cards {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
}

.session-card {
  position: relative;
  min-height: 128px;
  padding: 14px 10px;
  background: rgba(3, 14, 27, 0.8);
  border: 1px solid rgba(143, 204, 255, 0.18);
  border-radius: 18px;
  text-align: center;
  overflow: hidden;
}

.session-card::after {
  content: "◇";
  position: absolute;
  right: 10px;
  bottom: -18px;
  color: rgba(154, 223, 255, 0.08);
  font-size: 4rem;
}

.session-card.open {
  border-color: rgba(69, 210, 122, 0.8);
  box-shadow: 0 0 24px rgba(69, 210, 122, 0.12);
}

.session-card h3 {
  margin: 0 0 12px;
  font-size: 0.95rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.status {
  display: inline-flex;
  padding: 6px 12px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  color: var(--muted);
  font-weight: 800;
  font-size: 0.78rem;
}

.open .status {
  background: rgba(69, 210, 122, 0.16);
  color: #93f0b5;
}

.session-time { display: block; margin-top: 14px; color: var(--silver); font-size: 0.85rem; }
.session-zone { display: block; margin-top: 4px; color: var(--muted); font-size: 0.78rem; }
.local-time { display: block; margin-top: 8px; color: var(--blue); font-size: 0.82rem; }

.time-panel {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.time-panel > div {
  padding: 12px;
  border-radius: 18px;
  background: rgba(0, 0, 0, 0.17);
}

.panel-label {
  margin: 0 0 8px;
  color: var(--blue);
  font-size: 0.8rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.time-panel strong {
  display: block;
  font-size: clamp(1.9rem, 8vw, 3.8rem);
  letter-spacing: 0.03em;
}

.time-panel span, .time-panel em {
  display: block;
  color: var(--muted);
  font-style: normal;
  margin-top: 4px;
}

.market-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 10px;
}

.live-dot {
  display: flex;
  align-items: center;
  gap: 7px;
  color: var(--muted);
  font-size: 0.85rem;
}
.live-dot span {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 12px var(--green);
}

.data-warning {
  border: 1px solid rgba(255, 218, 105, 0.35);
  background: rgba(255, 218, 105, 0.08);
  color: #ffe08a;
  border-radius: 12px;
  padding: 10px;
  font-size: 0.86rem;
}
.hidden { display: none; }

.market-list {
  display: grid;
  gap: 8px;
}

.market-row {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 12px;
  align-items: center;
  padding: 12px;
  border-radius: 16px;
  background: rgba(2, 11, 21, 0.72);
  border: 1px solid rgba(143, 204, 255, 0.12);
}

.symbol { font-weight: 900; letter-spacing: 0.06em; }
.name { display: block; color: var(--muted); margin-top: 3px; font-size: 0.82rem; }
.price { color: var(--silver); font-variant-numeric: tabular-nums; }
.change { min-width: 84px; text-align: right; font-weight: 900; font-variant-numeric: tabular-nums; }
.change.bullish { color: var(--green); }
.change.bearish { color: var(--red); }

footer {
  margin-top: 14px;
  text-align: center;
  color: var(--muted);
  font-size: 0.78rem;
}

@media (max-width: 760px) {
  .session-cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .market-row { grid-template-columns: 1fr; gap: 6px; }
  .price, .change { text-align: left; }
}

@media (max-width: 430px) {
  .app-shell { padding: 10px 8px 24px; }
  .time-panel { grid-template-columns: 1fr; }
  .club-logo { width: 98%; max-height: 225px; }
  .hero { min-height: 275px; padding: 18px 8px 16px; }
  .eyebrow { font-size: 0.64rem; letter-spacing: 0.1em; }
  .subtitle { font-size: 0.88rem; }
}
